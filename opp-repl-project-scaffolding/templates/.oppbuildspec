<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!-- Template: .oppbuildspec for a new single-folder executable project.

     WHAT THIS FILE DOES
     This file is READ by `make makefiles`.  Its flags are only valid
     there — they are NOT valid on the `opp_makemake` command line.

     BOOTSTRAPPING (first build)
     The very first `Makefile` in a project must be generated by
     calling `opp_makemake` directly:

         opp_makemake -f --deep -o mm1k

     Do NOT pass --meta:* flags to opp_makemake itself — it will
     reject them.  They go here in .oppbuildspec.

     REGENERATION (after .oppbuildspec changes)
     Once a Makefile exists, `make makefiles` (which opp_repl wraps
     as make_makefiles()) reads this file and regenerates.

     REPLACE "mm1k" with your project name.  The `-o <name>` flag is
     what makes the executable name match what opp_repl's
     SimulationTask expects.

     Flag meanings (processed by `make makefiles`):
     --deep                     Recurse into subdirectories
     --meta:recurse             Enable deep makemake recursion
     --meta:export-library      Let other projects link against this one
     --meta:use-exported-libs   Auto-link against dependent projects
     -o mm1k                    Name the output executable mm1k
-->
<buildspec version="4.0">
    <dir
        makemake-options="--deep --meta:recurse --meta:export-library --meta:use-exported-libs -o mm1k"
        path="."
        type="makemake"/>
</buildspec>
